# Hevy API key — pobierz z ustawień aplikacji Hevy
HEVY_API_KEY=twoj_klucz_api

# Domena pod którą będzie dostępny serwer MCP (musi wskazywać na ten serwer DNS-em)
MCP_DOMAIN=hevy-mcp.twoja-domena.pl

# E-mail do Let's Encrypt (powiadomienia o wygasaniu certyfikatu)
ACME_EMAIL=twoj@email.pl

# Opcjonalne — basic auth dla Traefik (wygeneruj: htpasswd -nb user password)
# BASIC_AUTH=user:$$apr1$$hash
